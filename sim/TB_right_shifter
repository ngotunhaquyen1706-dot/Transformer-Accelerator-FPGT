module TB_right_shifter;

parameter before_data_width = 32;
parameter after_data_width  = 8;
parameter shift_width       = 5;

// DUT inputs
reg [shift_width-1:0] shift;
reg signed [before_data_width-1:0] data_in;

// DUT output
wire signed [after_data_width-1:0] data_out;

//--------------------------------------------------
// DUT
//--------------------------------------------------
right_shifter #(
    .before_data_width(before_data_width),
    .after_data_width(after_data_width),
    .shift_width(shift_width)
)
dut (
    .shift(shift),
    .data_in(data_in),
    .data_out(data_out)
);

//--------------------------------------------------
// Test Procedure
//--------------------------------------------------
initial begin

    $display("================================================");
    $display(" data_in\tshift\tdata_out");
    $display("================================================");

    //--------------------------------------------------
    // Test 1: shift = 0
    //--------------------------------------------------
    data_in = 32'sd100;
    shift   = 0;
    #10;

    //--------------------------------------------------
    // Test 2: arithmetic shift
    // 64 >> 2 = 16
    //--------------------------------------------------
    data_in = 32'sd64;
    shift   = 2;
    #10;

    //--------------------------------------------------
    // Test 3: rounding
    // 27 >> 2 = 6.75
    // rounded = 7
    //--------------------------------------------------
    data_in = 32'sd27;
    shift   = 2;
    #10;

    //--------------------------------------------------
    // Test 4: negative value
    // -32 >> 2 = -8
    //--------------------------------------------------
    data_in = -32'sd32;
    shift   = 2;
    #10;

    //--------------------------------------------------
    // Test 5: positive overflow
    // saturate to +127
    //--------------------------------------------------
    data_in = 32'sd500;
    shift   = 0;
    #10;

    //--------------------------------------------------
    // Test 6: negative overflow
    // saturate to -128
    //--------------------------------------------------
    data_in = -32'sd500;
    shift   = 0;
    #10;

    //--------------------------------------------------
    // Test 7: large shift
    //--------------------------------------------------
    data_in = 32'sd1024;
    shift   = 5;
    #10;

    //--------------------------------------------------
    // Test 8: rounding edge
    // 31 >> 2 = 7.75 -> 8
    //--------------------------------------------------
    data_in = 32'sd31;
    shift   = 2;
    #10;

    //--------------------------------------------------
    // Test 9: maximum INT8
    //--------------------------------------------------
    data_in = 32'sd127;
    shift   = 0;
    #10;

    //--------------------------------------------------
    // Test 10: minimum INT8
    //--------------------------------------------------
    data_in = -32'sd128;
    shift   = 0;
    #10;

    $finish;

end

//--------------------------------------------------
// Monitor
//--------------------------------------------------
initial begin
    $monitor("Time=%0t  data_in=%0d  shift=%0d  data_out=%0d",
              $time, data_in, shift, data_out);
end

endmodule
